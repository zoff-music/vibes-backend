{
	log {
		level ERROR
	}
	local_certs
}

http://localhost {
	redir https://{host}{uri}
}

localhost, 127.0.0.1 {
	# Handle Platform app Vite HMR WebSocket
	handle /vite-hmr* {
		reverse_proxy localhost:3002
	}

	# Handle Cast app HMR WebSocket (when accessed via /casting/receiver/)
	handle /casting/receiver/__hmr {
		reverse_proxy 127.0.0.1:3003
	}

	# Handle platform assets - proxy to Vite dev server
	handle /assets/platform/* {
		reverse_proxy {$PLATFORM_UPSTREAM:localhost:3001} {
			header_up Host {host}
		}
	}

	handle /api/v1/rooms/*/events {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			flush_interval -1
			header_up Host {host}
		}
	}

	handle /api/* {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			header_up Host {host}
		}
	}

	handle /metrics {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			header_up Host {host}
		}
	}

	handle /_healthz {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			header_up Host {host}
		}
	}

	# Cast receiver endpoint - proxy to dev server
	redir /casting/receiver /casting/receiver/
	handle /casting/receiver/* {
		reverse_proxy 127.0.0.1:3003 {
			header_up Host {host}
		}
	}

	# Main platform app - proxy to Vite dev server
	handle {
		reverse_proxy {$PLATFORM_UPSTREAM:localhost:3001} {
			header_up Host {host}
		}
	}
}
