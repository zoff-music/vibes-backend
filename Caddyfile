{
	log {
		level ERROR
	}
	local_certs
}

http://localhost {
	redir https://{host}{uri}
}

localhost, 127.0.0.1 {
	# Handle platform assets - proxy to platform server
	handle /assets/platform/* {
		reverse_proxy {$PLATFORM_UPSTREAM:localhost:3000} {
			header_up Host {host}
		}
	}

	handle /api/v1/rooms/*/events {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			flush_interval -1
			header_up Host {host}
		}
	}

	handle /api/* {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			header_up Host {host}
		}
	}

	handle /metrics {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			header_up Host {host}
		}
	}

	handle /_healthz {
		reverse_proxy {$BACKEND_UPSTREAM:localhost:8080} {
			header_up Host {host}
		}
	}

	# Cast receiver endpoint - proxy to dev server in development, static files in production
	redir /casting/receiver /casting/receiver/
	handle /casting/receiver/* {
		# In development, proxy to the cast dev server
		@dev `{$CAST_DEV_MODE:false}` == `true`
		reverse_proxy @dev {$CAST_UPSTREAM:localhost:3001} {
			header_up Host {host}
		}

		# In production, serve static files
		@prod `{$CAST_DEV_MODE:false}` != `true`
		handle @prod {
			root * frontend/apps/cast/dist
			uri strip_prefix /casting/receiver
			try_files {path} /index.html
			file_server
		}
	}

	handle {
		reverse_proxy {$PLATFORM_UPSTREAM:localhost:3000}
	}
}
