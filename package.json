{
  "name": "vibez",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @vibez/mobile dev",
    "dev:web": "pnpm --filter @vibez/mobile dev:web",
    "build": "pnpm --filter @vibez/mobile build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "backend": "cd backend && go run cmd/server/main.go",
    "backend:build": "cd backend && go build -o bin/server cmd/server/main.go"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.0.0"
}
