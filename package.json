{
  "name": "vibez",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter @vibez/mobile dev",
    "dev:web": "bun --filter @vibez/mobile dev:web",
    "build": "bun --filter @vibez/mobile build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "backend": "cd backend && go run cmd/server/main.go",
    "backend:build": "cd backend && go build -o bin/server cmd/server/main.go"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "wiretyped": "^0.3.4"
  }
}
