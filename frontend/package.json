{
  "name": "vibez",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @vibez/platform dev",
    "build": "bun --filter @vibez/platform build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint",
    "test": "bun run --filter '*' test",
    "fix": "bunx biome check --write --unsafe ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "typescript": "^5.3.0",
    "vite": "^6.0.1",
    "@vitejs/plugin-react": "^4.3.4"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "wiretyped": "^0.3.4"
  }
}
