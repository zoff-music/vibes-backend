{
  "name": "@vibez/cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3003",
    "build": "bun run build:css && bun run build:client",
    "build:css": "bun run tailwindcss -i src/styles/index.css -o dist/tailwind.css --minify",
    "build:client": "NODE_ENV=production bun scripts/build.ts",
    "preview": "echo 'Use Caddy to preview the static build'",
    "lint": "bunx biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibez/api": "workspace:*",
    "@vibez/models": "workspace:*",
    "@vibez/shared": "workspace:*",
    "@vibez/ui": "workspace:*",
    "qrcode.react": "^4.2.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-player": "^2.16.0",
    "react-router": "^7.12.0",
    "react-spotify-web-playback": "^0.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.6",
    "@types/chromecast-caf-receiver": "^6.0.1",
    "@types/node": "^25.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.6.2",
    "vite": "^6.0.7",
    "vitest": "^4.0.17"
  }
}
