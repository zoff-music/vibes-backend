{
  "name": "@vibez/cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3003",
    "build": "bun run build:css && bun run build:client",
    "build:css": "bun run tailwindcss -i src/styles/index.css -o dist/index.css --minify",
    "build:client": "NODE_ENV=production bun scripts/build.ts",
    "preview": "echo 'Use Caddy to preview the static build'",
    "lint": "bunx biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vibez/api": "workspace:*",
    "@vibez/models": "workspace:*",
    "@vibez/shared": "workspace:*",
    "@vibez/ui": "workspace:*",
    "qrcode.react": "^4.2.0",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-player": "^3.4.0",
    "react-router": "^7.13.0",
    "react-spotify-web-playback": "^0.14.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "^1.3.6",
    "@types/chromecast-caf-receiver": "^6.0.25",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
