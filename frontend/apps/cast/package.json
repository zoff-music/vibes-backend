{
  "name": "@vibez/cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run build:css --watch & bun scripts/build.ts --watch & bun scripts/dev-server.ts",
    "build": "bun run build:css && bun run build:static",
    "build:css": "bunx @tailwindcss/cli -i src/index.css -o dist/index.css --minify",
    "build:static": "NODE_ENV=production bun scripts/build.ts",
    "start": "echo 'Cast app is now static - serve via Caddy'",
    "lint": "bunx biome check .",
    "typecheck": "tsc --noEmit",
    "preview": "echo 'Use Caddy to preview the static build'",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vibez/models": "workspace:*",
    "@vibez/player": "workspace:*",
    "@vibez/shared": "workspace:*",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-player": "^2.16.0",
    "react-router": "^7.12.0",
    "react-spotify-web-playback": "^0.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bun": "^1.3.6",
    "@types/chromecast-caf-receiver": "^6.0.1",
    "@types/node": "^25.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2"
  }
}
