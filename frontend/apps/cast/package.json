{
  "name": "@vibez/cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/build.ts --watch & bun run server.tsx",
    "build": "bun run build:css && bun run build:client && bun run build:server",
    "build:css": "bunx @tailwindcss/cli -i src/index.css -o dist/assets/cast/index.css --minify",
    "build:client": "NODE_ENV=production bun scripts/build.ts",
    "build:server": "bun build server.tsx --outdir ./dist/server --target bun --minify",
    "start": "NODE_ENV=production bun dist/server/server.js",
    "lint": "bunx biome check .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vibez/models": "workspace:*",
    "@vibez/player": "workspace:*",
    "@vibez/shared": "workspace:*",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-player": "^2.16.0",
    "react-router": "^7.12.0",
    "react-spotify-web-playback": "^0.14.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bun": "^1.3.6",
    "@types/chromecast-caf-receiver": "^6.0.1",
    "@types/node": "^25.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "globals": "^15.12.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2"
  }
}
