{
  "name": "@vibez/platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:css && bun run build:client && bun run build:server",
    "build:css": "bun run tailwindcss -i src/index.css -o dist/assets/platform/index.css --minify",
    "build:client": "NODE_ENV=production bun scripts/build.ts",
    "build:server": "bun build server.tsx --outdir ./dist/server --target bun --minify --external react-player",
    "start": "NODE_ENV=production bun dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src",
    "test:e2e": "playwright test",
    "test": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vibez/api": "workspace:*",
    "@vibez/models": "workspace:*",
    "@vibez/shared": "workspace:*",
    "@vibez/ui": "workspace:*",
    "framer-motion": "^12.29.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-player": "^3.4.0",
    "react-router": "^7.13.0",
    "react-spotify-web-playback": "^0.14.7",
    "react-youtube": "^10.1.0",
    "wiretyped": "^0.3.4",
    "yup": "^1.7.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.3.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}