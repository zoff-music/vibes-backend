{
  "name": "@vibez/platform",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run tailwindcss -i src/index.css -o dist/assets/platform/index.css --config tailwind.config.js --watch\" \"bun scripts/build.ts --watch\" \"bun run --hot server.tsx\"",
    "build": "bun run build:css && bun run build:client && bun run build:server",
    "build:css": "bun run tailwindcss -i src/index.css -o dist/assets/platform/index.css --minify --config tailwind.config.js",
    "build:client": "NODE_ENV=production bun scripts/build.ts",
    "build:server": "bun build server.tsx --outdir ./dist/server --target bun --minify",
    "start": "NODE_ENV=production bun dist/server/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src",
    "test:e2e": "playwright test",
    "test": "vitest"
  },
  "dependencies": {
    "@vibez/api": "workspace:*",
    "@vibez/models": "workspace:*",
    "@vibez/shared": "workspace:*",
    "framer-motion": "^12.26.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-player": "^3.4.0",
    "react-router": "^7.12.0",
    "react-spotify-web-playback": "^0.14.7",
    "react-youtube": "^10.1.0",
    "wiretyped": "^0.3.4",
    "yup": "^1.7.1",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.3.3",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.2",
    "vitest": "^4.0.17"
  }
}
